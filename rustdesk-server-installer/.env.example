# ==============================================================================
# RustDesk Server - 环境变量配置
# ==============================================================================
#
# 说明：
#   复制此文件为 .env 并根据需要修改配置
#   使用方法：cp .env.example .env
#
# ==============================================================================

# ------------------------------------------------------------------------------
# RustDesk 核心配置
# ------------------------------------------------------------------------------

# 强制使用中继服务器（N: 自动模式，Y: 强制中继）
# 默认：N（自动模式，优先 P2P，失败后使用中继）
ALWAYS_USE_RELAY=N

# 密钥长度（比特）
# 默认：32
# 建议：不要修改，除非有特殊需求
KEY_LEN=32

# 端口偏移量
# 默认：0
# 说明：如果默认端口被占用，可以设置偏移量（如 1000，则 21114 变为 22114）
PORT_OFFSET=0

# ------------------------------------------------------------------------------
# Docker 配置
# ------------------------------------------------------------------------------

# Docker Compose 项目名称
# 默认：rustdesk-server
COMPOSE_PROJECT_NAME=rustdesk-server

# Docker 镜像标签
# 默认：latest（最新稳定版）
# 可选：指定版本号，如 v1.1.10
IMAGE_TAG=latest

# 容器重启策略
# 默认：unless-stopped（除非手动停止，否则总是重启）
# 可选：no（不重启）、on-failure（失败时重启）、always（总是重启）
RESTART_POLICY=unless-stopped

# ------------------------------------------------------------------------------
# 网络配置（仅在不使用 host 网络模式时需要）
# ------------------------------------------------------------------------------

# 如果不使用 host 网络模式（非 Linux 系统），需要取消以下注释并配置端口
# 注意：host 网络模式（Linux 默认）不需要这些配置

# HBBS 端口配置
# HBBS_PORT_21114=21114
# HBBS_PORT_21115=21115
# HBBS_PORT_21116=21116
# HBBS_PORT_21116_UDP=21116
# HBBS_PORT_21118=21118

# HBBR 端口配置
# HBBR_PORT_21117=21117
# HBBR_PORT_21119=21119

# ------------------------------------------------------------------------------
# 高级配置（一般不需要修改）
# ------------------------------------------------------------------------------

# 日志级别
# 默认：info
# 可选：off, error, warn, info, debug, trace
LOG_LEVEL=info

# 数据目录
# 默认：./data（相对路径，指向安装目录下的 data 文件夹）
# 注意：修改后需要确保目录存在且有正确权限
DATA_DIR=./data

# 限制内存使用（可选）
# 默认：无限制
# 示例：限制容器最大使用 512MB 内存
# MEMORY_LIMIT=512m

# 限制 CPU 使用（可选）
# 默认：无限制
# 示例：限制容器最多使用 0.5 个 CPU 核心
# CPU_LIMIT=0.5
